<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VaultDrive – Your Personal File Storage</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-base:        #0e0f13;
      --bg-surface:     #161820;
      --bg-elevated:    #1e2029;
      --bg-card:        #23262f;
      --border:         #2e3140;
      --accent:         #5c6ef8;
      --accent-glow:    rgba(92, 110, 248, 0.25);
      --accent-soft:    #3d4fc2;
      --text-primary:   #e8eaf0;
      --text-secondary: #8b8fa8;
      --text-muted:     #555970;
      --success:        #3ecf8e;
      --warning:        #f59e0b;
      --danger:         #f04e5e;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--bg-base);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── Background grid ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.35;
      pointer-events: none;
      z-index: 0;
    }

    /* ── Glow blob ── */
    body::after {
      content: '';
      position: fixed;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 500px;
      background: radial-gradient(ellipse, rgba(92,110,248,0.18) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── Nav ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(14,15,19,0.82);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }

    .nav-logo {
      font-family: 'Space Mono', monospace;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-primary);
      text-decoration: none;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-logo .logo-dot {
      width: 8px;
      height: 8px;
      background: var(--accent);
      border-radius: 50%;
      box-shadow: 0 0 8px var(--accent);
    }

    .nav-actions { display: flex; gap: 0.75rem; align-items: center; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0.45rem 1.1rem;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
      border: none;
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-secondary);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover {
      color: var(--text-primary);
      border-color: var(--accent);
      background: var(--accent-glow);
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 0 20px var(--accent-glow);
    }
    .btn-primary:hover {
      background: #6c7ff9;
      box-shadow: 0 0 28px rgba(92,110,248,0.45);
      transform: translateY(-1px);
    }

    .btn-lg {
      padding: 0.75rem 1.75rem;
      font-size: 1rem;
      border-radius: 8px;
    }

    /* ── Hero ── */
    .hero {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 7rem 1.5rem 5rem;
      max-width: 780px;
      margin: 0 auto;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0.3rem 0.9rem;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 99px;
      font-size: 0.78rem;
      color: var(--accent);
      margin-bottom: 2rem;
      font-family: 'Space Mono', monospace;
      letter-spacing: 0.05em;
      animation: fadeDown 0.6s ease both;
    }

    h1 {
      font-size: clamp(2.4rem, 6vw, 4rem);
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -1px;
      margin-bottom: 1.25rem;
      animation: fadeDown 0.6s 0.1s ease both;
    }

    h1 span {
      background: linear-gradient(135deg, #7c8dfa, #c084fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 520px;
      margin: 0 auto 2.5rem;
      animation: fadeDown 0.6s 0.2s ease both;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      animation: fadeDown 0.6s 0.3s ease both;
    }

    /* ── Stats strip ── */
    .stats {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      gap: 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--bg-surface);
      margin-bottom: 5rem;
    }

    .stat-item {
      flex: 1;
      max-width: 220px;
      padding: 1.5rem 1rem;
      text-align: center;
      border-right: 1px solid var(--border);
    }
    .stat-item:last-child { border-right: none; }

    .stat-num {
      font-family: 'Space Mono', monospace;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-top: 2px;
    }

    /* ── Features ── */
    .section {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem 5rem;
    }

    .section-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.6rem;
    }

    .section-title {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 600;
      letter-spacing: -0.5px;
      margin-bottom: 2.5rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
    }

    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .feature-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(92,110,248,0.15);
    }

    .feature-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.1rem;
      color: var(--accent);
    }

    .feature-icon .material-icons { font-size: 22px; }

    .feature-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
      color: var(--text-primary);
    }

    .feature-desc {
      font-size: 0.88rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* ── Upload demo card ── */
    .demo-section {
      position: relative;
      z-index: 1;
      max-width: 640px;
      margin: 0 auto 5rem;
      padding: 0 1.5rem;
    }

    .upload-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
    }

    .upload-card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .upload-drop {
      border: 2px dashed var(--border);
      border-radius: 10px;
      padding: 2.5rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      margin-bottom: 1.25rem;
    }
    .upload-drop:hover {
      border-color: var(--accent);
      background: var(--accent-glow);
    }

    .upload-drop .material-icons {
      font-size: 40px;
      color: var(--text-muted);
      display: block;
      margin-bottom: 0.75rem;
    }

    .upload-drop p {
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .upload-drop span {
      color: var(--accent);
      cursor: pointer;
    }

    .upload-drop small {
      display: block;
      margin-top: 4px;
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .file-list { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.25rem; }

    .file-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.65rem 0.9rem;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.875rem;
    }

    .file-item .material-icons { font-size: 18px; color: var(--accent); }

    .file-item-name { flex: 1; color: var(--text-primary); }

    .file-item-size { color: var(--text-muted); font-size: 0.8rem; font-family: 'Space Mono', monospace; }

    .file-item-status {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--success);
      box-shadow: 0 0 6px var(--success);
    }

    /* ── Footer ── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 2rem 1.5rem;
      text-align: center;
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    footer a { color: var(--text-muted); text-decoration: none; }
    footer a:hover { color: var(--accent); }

    /* ── Animations ── */
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .stats { flex-wrap: wrap; }
      .stat-item { border-right: none; border-bottom: 1px solid var(--border); max-width: 100%; }
      .stat-item:last-child { border-bottom: none; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">
      <span class="logo-dot"></span>
      VaultDrive
    </a>
    <div class="nav-actions">
      <% if (user) { %>
        <a href="/dashboard" class="btn btn-ghost">
          <span class="material-icons" style="font-size:16px">dashboard</span>
          Dashboard
        </a>
        <a href="/logout" class="btn btn-ghost">Logout</a>
      <% } else { %>
        <a href="/login" class="btn btn-ghost">Sign in</a>
        <a href="/register" class="btn btn-primary">Get started</a>
      <% } %>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">
      <span class="material-icons" style="font-size:13px">bolt</span>
      Secure cloud file storage
    </div>
    <h1>Store, manage & share<br><span>your files with ease</span></h1>
    <p class="hero-sub">
      A personal drive for all your documents, images, and more.
      Organize with folders, share with links, and access from anywhere.
    </p>
    <div class="hero-cta">
      <% if (user) { %>
        <a href="/dashboard" class="btn btn-primary btn-lg">
          <span class="material-icons" style="font-size:18px">folder_open</span>
          Open Dashboard
        </a>
      <% } else { %>
        <a href="/register" class="btn btn-primary btn-lg">
          <span class="material-icons" style="font-size:18px">rocket_launch</span>
          Start for free
        </a>
        <a href="/login" class="btn btn-ghost btn-lg">Sign in</a>
      <% } %>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat-item">
      <div class="stat-num">10 GB</div>
      <div class="stat-label">Free storage</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">AES-256</div>
      <div class="stat-label">Encryption</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">∞</div>
      <div class="stat-label">Folders</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">99.9%</div>
      <div class="stat-label">Uptime</div>
    </div>
  </div>

  <!-- FEATURES -->
  <section class="section">
    <div class="section-label">Features</div>
    <h2 class="section-title">Everything you need in one place</h2>
    <div class="features-grid">

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">upload_file</span>
        </div>
        <div class="feature-title">Easy Uploads</div>
        <p class="feature-desc">Drag and drop any file — images, PDFs, documents, and more. Powered by Multer with file type and size validation.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">folder_special</span>
        </div>
        <div class="feature-title">Folder Organization</div>
        <p class="feature-desc">Create, rename, and delete folders to keep everything organized. Nest files exactly how you want them.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">share</span>
        </div>
        <div class="feature-title">Share via Link</div>
        <p class="feature-desc">Generate expiring share links for any folder. Anyone with the link can view its contents — no account needed.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">download</span>
        </div>
        <div class="feature-title">View & Download</div>
        <p class="feature-desc">See file details like name, size, and upload time. Download any file instantly with a single click.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">lock</span>
        </div>
        <div class="feature-title">Secure Auth</div>
        <p class="feature-desc">Session-based authentication via Passport.js. Your files are private and only accessible when you're logged in.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">cloud_done</span>
        </div>
        <div class="feature-title">Cloud Storage</div>
        <p class="feature-desc">Files are stored in Cloudinary or Supabase. Persistent, reliable, and accessible from any device.</p>
      </div>

    </div>
  </section>

  <!-- UPLOAD DEMO CARD -->
  <div class="demo-section">
    <div class="upload-card">
      <h3>
        <span class="material-icons" style="color: var(--accent); font-size:20px">drive_folder_upload</span>
        Upload a file
      </h3>

      <div class="upload-drop" onclick="document.getElementById('fileInput').click()">
        <span class="material-icons">cloud_upload</span>
        <p>Drag & drop files here, or <span>browse</span></p>
        <small>Max 10MB · PNG, JPG, PDF, DOCX and more</small>
      </div>
      <input type="file" id="fileInput" style="display:none"/>

      <!-- Example file list (would be dynamic) -->
      <div class="file-list">
        <div class="file-item">
          <span class="material-icons">picture_as_pdf</span>
          <span class="file-item-name">project-brief.pdf</span>
          <span class="file-item-size">2.4 MB</span>
          <span class="file-item-status"></span>
        </div>
        <div class="file-item">
          <span class="material-icons">image</span>
          <span class="file-item-name">screenshot.png</span>
          <span class="file-item-size">840 KB</span>
          <span class="file-item-status"></span>
        </div>
      </div>

      <% if (user) { %>
        <a href="/upload" class="btn btn-primary" style="width:100%; justify-content:center;">
          <span class="material-icons" style="font-size:16px">upload</span>
          Upload now
        </a>
      <% } else { %>
        <a href="/register" class="btn btn-primary" style="width:100%; justify-content:center;">
          <span class="material-icons" style="font-size:16px">person_add</span>
          Sign up to upload
        </a>
      <% } %>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <p>Built with Express · Prisma · Passport · Multer &nbsp;|&nbsp; <a href="https://www.theodinproject.com" target="_blank">The Odin Project</a></p>
  </footer>

</body>
</html>
