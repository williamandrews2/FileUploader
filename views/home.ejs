<!-- HERO -->
  <section class="hero">
    <div class="hero-badge">
      <span class="material-icons" style="font-size:13px">bolt</span>
      Secure cloud file storage
    </div>
    <h1>Store, manage & share<br><span>your files with ease</span></h1>
    <p class="hero-sub">
      A personal drive for all your documents, images, and more.
      Organize with folders, share with links, and access from anywhere.
    </p>
    <div class="hero-cta">
      <% if (user) { %>
        <a href="/dashboard" class="btn btn-primary btn-lg">
          <span class="material-icons" style="font-size:18px">folder_open</span>
          Open Dashboard
        </a>
      <% } else { %>
        <a href="/register" class="btn btn-primary btn-lg">
          <span class="material-icons" style="font-size:18px">rocket_launch</span>
          Start for free
        </a>
        <a href="/login" class="btn btn-ghost btn-lg">Sign in</a>
      <% } %>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat-item">
      <div class="stat-num">10 GB</div>
      <div class="stat-label">Free storage</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">AES-256</div>
      <div class="stat-label">Encryption</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">∞</div>
      <div class="stat-label">Folders</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">99.9%</div>
      <div class="stat-label">Uptime</div>
    </div>
  </div>

  <!-- FEATURES -->
  <section class="section">
    <div class="section-label">Features</div>
    <h2 class="section-title">Everything you need in one place</h2>
    <div class="features-grid">

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">upload_file</span>
        </div>
        <div class="feature-title">Easy Uploads</div>
        <p class="feature-desc">Drag and drop any file — images, PDFs, documents, and more. Powered by Multer with file type and size validation.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">folder_special</span>
        </div>
        <div class="feature-title">Folder Organization</div>
        <p class="feature-desc">Create, rename, and delete folders to keep everything organized. Nest files exactly how you want them.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">share</span>
        </div>
        <div class="feature-title">Share via Link</div>
        <p class="feature-desc">Generate expiring share links for any folder. Anyone with the link can view its contents — no account needed.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">download</span>
        </div>
        <div class="feature-title">View & Download</div>
        <p class="feature-desc">See file details like name, size, and upload time. Download any file instantly with a single click.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">lock</span>
        </div>
        <div class="feature-title">Secure Auth</div>
        <p class="feature-desc">Session-based authentication via Passport.js. Your files are private and only accessible when you're logged in.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <span class="material-icons">cloud_done</span>
        </div>
        <div class="feature-title">Cloud Storage</div>
        <p class="feature-desc">Files are stored in Cloudinary or Supabase. Persistent, reliable, and accessible from any device.</p>
      </div>

    </div>
  </section>

  <!-- UPLOAD DEMO CARD -->
  <div class="demo-section">
    <div class="upload-card">
      <h3>
        <span class="material-icons" style="color: var(--accent); font-size:20px">drive_folder_upload</span>
        Upload a file
      </h3>

      <div class="upload-drop" onclick="document.getElementById('fileInput').click()">
        <span class="material-icons">cloud_upload</span>
        <p>Drag & drop files here, or <span>browse</span></p>
        <small>Max 10MB · PNG, JPG, PDF, DOCX and more</small>
      </div>
      <input type="file" id="fileInput" style="display:none"/>

      <!-- Example file list (would be dynamic) -->
      <div class="file-list">
        <div class="file-item">
          <span class="material-icons">picture_as_pdf</span>
          <span class="file-item-name">project-brief.pdf</span>
          <span class="file-item-size">2.4 MB</span>
          <span class="file-item-status"></span>
        </div>
        <div class="file-item">
          <span class="material-icons">image</span>
          <span class="file-item-name">screenshot.png</span>
          <span class="file-item-size">840 KB</span>
          <span class="file-item-status"></span>
        </div>
      </div>

      <% if (user) { %>
        <a href="/upload" class="btn btn-primary" style="width:100%; justify-content:center;">
          <span class="material-icons" style="font-size:16px">upload</span>
          Upload now
        </a>
      <% } else { %>
        <a href="/register" class="btn btn-primary" style="width:100%; justify-content:center;">
          <span class="material-icons" style="font-size:16px">person_add</span>
          Sign up to upload
        </a>
      <% } %>
    </div>
  </div>