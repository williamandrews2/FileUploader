<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VaultDrive – Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
</head>
<body>

  <!-- DASHBOARD -->
  <div class="dashboard">

    <!-- Header -->
    <div class="dashboard-header">
      <div class="dashboard-title">
        <h1>My Drive</h1>
        <p>Manage your folders and files</p>
      </div>
      <div class="dashboard-actions">
        <a href="/folders/new" class="btn btn-ghost">
          <span class="material-icons" style="font-size:16px">create_new_folder</span>
          New Folder
        </a>
        <a href="/upload" class="btn btn-primary">
          <span class="material-icons" style="font-size:16px">upload_file</span>
          Upload File
        </a>
      </div>
    </div>

    <!-- FOLDERS -->
    <div class="folders-section">
      <div class="section-header">
        <div class="section-header-left">
          <span class="material-icons">folder</span>
          <span class="section-heading">Folders</span>
        </div>
        <span class="section-count"><%= folders.length %></span>
      </div>

      <% if (folders.length === 0) { %>
        <div class="empty-state">
          <span class="material-icons">folder_open</span>
          <p>No folders yet</p>
          <a href="/folders/new" class="btn btn-ghost">
            <span class="material-icons" style="font-size:16px">create_new_folder</span>
            Create your first folder
          </a>
        </div>
      <% } else { %>
        <div class="folders-grid">
          <% folders.forEach(function(folder) { %>
            <div class="folder-card">
              <div class="folder-card-icon">
                <span class="material-icons">folder</span>
              </div>
              <div class="folder-card-name"><%= folder.name %></div>
              <div class="folder-card-meta">
                <%= new Date(folder.createdAt).toLocaleDateString() %>
              </div>
              <div class="folder-card-actions">
                <a href="/folders/<%= folder.id %>" class="icon-btn" title="Open">
                  <span class="material-icons">open_in_new</span>
                </a>
                <a href="/folders/<%= folder.id %>/edit" class="icon-btn" title="Rename">
                  <span class="material-icons">edit</span>
                </a>
                <form action="/folders/<%= folder.id %>/delete" method="POST" style="margin:0;">
                  <button type="submit" class="icon-btn danger" title="Delete">
                    <span class="material-icons">delete</span>
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="dash-divider"></div>

    <!-- FILES -->
    <div class="files-section">
      <div class="section-header">
        <div class="section-header-left">
          <span class="material-icons">insert_drive_file</span>
          <span class="section-heading">Files</span>
        </div>
        <span class="section-count"><%= files.length %></span>
      </div>

      <% if (files.length === 0) { %>
        <div class="empty-state">
          <span class="material-icons">upload_file</span>
          <p>No files uploaded yet</p>
          <a href="/upload" class="btn btn-ghost">
            <span class="material-icons" style="font-size:16px">upload</span>
            Upload your first file
          </a>
        </div>
      <% } else { %>
        <div class="files-list">
          <% files.forEach(function(file) { %>
            <div class="file-row">
              <div class="file-row-icon">
                <span class="material-icons">insert_drive_file</span>
              </div>
              <div class="file-row-info">
                <div class="file-row-name"><%= file.fileName %></div>
                <div class="file-row-meta">
                  <%= (file.fileSize / 1024).toFixed(1) %> KB &nbsp;·&nbsp;
                  <%= file.mimeType %> &nbsp;·&nbsp;
                  <%= new Date(file.createdAt).toLocaleDateString() %>
                </div>
              </div>
              <div class="file-row-actions">
                <a href="/<%= file.id %>/details" class="icon-btn" title="Details">
                  <span class="material-icons">info</span>
                </a>
                <a href="/<%= file.id %>/download" class="icon-btn" title="Download" target="_blank">
                  <span class="material-icons">download</span>
                </a>
                <form action="/<%= file.id %>/delete" method="POST" style="margin:0;">
                  <button type="submit" class="icon-btn danger" title="Delete">
                    <span class="material-icons">delete</span>
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>

</body>
</html>
