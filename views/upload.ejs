<div class="page">
  <div class="demo-section">
    <div class="upload-card">
      <h3>
        <span
          class="material-icons"
          style="color: var(--accent); font-size: 20px"
          >drive_folder_upload</span
        >
        Upload a file
      </h3>

      <% if (locals.error) { %>
       <div class="alert-error">
       <span class="material-icons">error_outline</span>
       <%= error %>
       </div>
      <% } %>

      <!-- multipart.form-data is required for multer to receive the file! -->
      <form action="/upload" method="POST" enctype="multipart/form-data">
        <div
          class="upload-drop"
          id="dropZone"
          onclick="document.getElementById('fileInput').click()"
        >
          <span class="material-icons">cloud_upload</span>
          <p>Drag & drop files here, or <span>browse</span></p>
          <small>Max 10MB · PNG, JPG, PDF, DOCX and more</small>
        </div>
        <input type="file" name="file" id="fileInput" style="display: none" />
        <input
          type="hidden"
          name="folderId"
          value="<%= locals.folderId || '' %>"
        />
        <button
          type="submit"
          class="btn btn-primary"
          style="width: 100%; justify-content: center; margin-top: 1.25rem"
        >
          <span class="material-icons" style="font-size: 16px">upload</span>
          Upload now
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  // alert for when user attempts to click upload without selecting a file first
  document.querySelector("form").addEventListener("submit", (e) => {
    const fileInput = document.getElementById("fileInput");
    if (!fileInput || fileInput.files.length === 0) {
      e.preventDefault();
      alert("Please select a file before uploading!");
    }
  });

  // drop zone event listener for dragging and dropping files to upload
  const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault(); // required to allow dropping
      dropZone.style.borderColor = 'var(--accent)';
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.style.borderColor = '';
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        fileInput.files = files; // assign dropped file to the input
        dropZone.querySelector('p').textContent = files[0].name; // show filename
        dropZone.style.borderColor = 'var(--success)';
      }
    });

    // show the file name when uploading by clicking "browse"
    fileInput.addEventListener('change', () => {
      if (fileInput.files.length > 0) {
        dropZone.querySelector('p').textContent = fileInput.files[0].name;
        dropZone.style.borderColor = 'var(--success)';
      }
    })
</script>
